# Rendered infographic PNGs are produced locally into epl/output (git-ignored);
# the tracked, published copies live in epl_png/.
epl/output/

# Internal scraper cookie / matchCentre caches
epl/matches/**/match_*_cache.json

# Private configuration / credentials
.env

# Python caching
__pycache__/
*.py[cod]

# Local virtual environments
venv/
.venv/
env/

# Logs
*.log

# Raw WhoScored match JSONs are huge (~2MB each); the dashboard uses the derived
# epl_dashboard/matches_detail/*.js instead. Keep raw scrapes local only.
epl/matches/20*/*.json
# Scratch id lists written by the resilient scraper (harvest cache / gap-fill candidates)
epl/matches/**/_*.txt
epl_dashboard/matches_detail/.calibrated
